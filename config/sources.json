  "discovery": {
    "description": "每週一次的探索搜尋，用於發現新來源，通過品質門檻的來源才加入白名單",
    "queries_en": [
      "\"how we increased\" conversion redesign case study",
      "\"how we reduced\" churn UX case study",
      "design ROI \"case study\" metrics",
      "product redesign \"A/B test\" \"lessons learned\""
